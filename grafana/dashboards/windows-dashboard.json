{
  "title": "Windows VPS Monitor",
  "uid": "windows-vps-custom",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "15s",
  "panels": [
    {
      "id": 1,
      "title": "CPU Usage %",
      "type": "gauge",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 6 },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 90 }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "efi62cdqw969sc" },
          "expr": "100 - (avg by (instance) (rate(windows_cpu_time_total{mode='idle', instance='173.248.136.194:9182'}[5m])) * 100)",
          "legendFormat": "CPU %"
        }
      ]
    },
    {
      "id": 3,
      "title": "Available Memory",
      "type": "stat",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 6 },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 500000000 },
              { "color": "green", "value": 1000000000 }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "efi62cdqw969sc" },
          "expr": "windows_memory_available_bytes{instance='173.248.136.194:9182'}",
          "legendFormat": "Available"
        }
      ]
    },
    {
      "id": 4,
      "title": "Windows VPS - Up/Down",
      "type": "stat",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 6 },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "efi62cdqw969sc" },
          "expr": "up{instance='173.248.136.194:9182'}",
          "legendFormat": "Windows VPS"
        }
      ]
    },
    {
      "id": 7,
      "title": "Disk Free Space",
      "type": "bargauge",
      "gridPos": { "x": 0, "y": 6, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 5000000000 },
              { "color": "green", "value": 20000000000 }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "efi62cdqw969sc" },
          "expr": "windows_logical_disk_free_bytes{instance='173.248.136.194:9182', volume!='HarddiskVolume1'}",
          "legendFormat": "Drive {{volume}}"
        }
      ]
    },
    {
      "id": 8,
      "title": "Network In/Out",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 6, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "Bps"
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "efi62cdqw969sc" },
          "expr": "rate(windows_net_bytes_received_total{instance='173.248.136.194:9182'}[5m])",
          "legendFormat": "In - {{nic}}"
        },
        {
          "datasource": { "type": "prometheus", "uid": "efi62cdqw969sc" },
          "expr": "rate(windows_net_bytes_sent_total{instance='173.248.136.194:9182'}[5m])",
          "legendFormat": "Out - {{nic}}"
        }
      ]
    }
  ],
  "time": { "from": "now-1h", "to": "now" }
}
